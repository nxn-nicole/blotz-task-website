---
// Root redirect: send users to /en/ or /zh/ based on browser language.
// This page is never displayed — it only runs the script below.
---
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <script is:inline>
    const lang = navigator.language.toLowerCase().startsWith('zh') ? '/zh/' : '/en/';
    location.replace(lang);
  </script>
</head>
<body></body>
</html>
